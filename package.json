{
  "name": "stepscalc",
  "version": "1.0.3",
  "description": "Set a goal for the month and use this at any time to calculate how many steps you need to take each day to reach your goal by the end of the month.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run --run --coverage --typecheck",
    "test:watch": "vitest --watch",
    "coverage": "vitest --ui --coverage",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "homepage": "https://penguinofthunder.github.io/stepscalc/",
  "bugs": "https://github.com/PenguinOfThunder/stepscalc/issues",
  "repository": {
    "url": "https://github.com/PenguinOfThunder/stepscalc.git",
    "type": "git"
  },
  "author": {
    "name": "PenguinOfThunder",
    "url": "https://github.com/PenguinOfThunder"
  },
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vite-pwa/assets-generator": "1.0.2",
    "@vitejs/plugin-react": "6.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.0",
    "jsdom": "29.1.1",
    "sass-embedded": "1.100.0",
    "standard": "17.1.2",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "chart.js": "4.5.1",
    "chartjs-plugin-annotation": "3.1.0",
    "classnames": "2.5.1",
    "date-fns": "4.4.0",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "react": "19.2.8",
    "react-bootstrap": "2.10.10",
    "react-bootstrap-icons": "1.11.6",
    "react-chartjs-2": "5.3.1",
    "react-dom": "19.2.8",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.11",
    "react-router": "7.18.1",
    "react-transition-group": "4.4.5",
    "zustand": "5.0.14"
  },
  "editorconfig": ".editorconfig",
  "prettier": {
    "arrowParens": "always",
    "tabWidth": 2,
    "endOfLine": "auto",
    "bracketSpacing": true,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "bracketSameLine": true,
    "trailingComma": "none",
    "useTabs": false,
    "proseWrap": "preserve",
    "quoteProps": "consistent",
    "semi": true,
    "htmlWhitespaceSensitivity": "css",
    "singleAttributePerLine": true
  }
}
